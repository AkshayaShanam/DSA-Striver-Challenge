class Solution {
    public List<List<Integer>> combinationSum(int[] candidates, int target) {
        List<List<Integer>> res=new ArrayList<>();
        backtrack(res,new ArrayList<>(),candidates,target,0,candidates.length);
        return res;
    }
    public void backtrack(List<List<Integer>> res,ArrayList<Integer> temp,int[] candidates,int target,int index,int n){
        if(index==n){
            if(target==0){
                res.add(new ArrayList<>(temp));
            }
            return;
        }
        if(candidates[index]<=target){
            temp.add(candidates[index]);
            backtrack(res,temp,candidates,target-candidates[index],index,n);
            temp.remove(temp.size()-1);
        }
        backtrack(res,temp,candidates,target,index+1,n);
    }
}
