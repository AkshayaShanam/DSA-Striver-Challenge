class Solution {
    public void combinationsum2(int idx,int[] candidates,int n,List<Integer> ds,List<List<Integer>> list,int target){
        if(target==0){
            list.add(new ArrayList<>(ds));
            return;
        }
        for(int i=idx;i<n;i++){
            if (i > idx && candidates[i] == candidates[i - 1]) continue;
            if(candidates[i]<=target){
                ds.add(candidates[i]);
                combinationsum2(i+1,candidates,n,ds,list,target-candidates[i]);
                ds.remove(ds.size()-1);
            }else{
                break;
            }
        }
    }
    public List<List<Integer>> combinationSum2(int[] candidates, int target) {
        List<List<Integer>> list=new ArrayList<>();
        int n=candidates.length;
        Arrays.sort(candidates);
        combinationsum2(0,candidates,n,new ArrayList<>(),list,target);
        return list;
    }
}
