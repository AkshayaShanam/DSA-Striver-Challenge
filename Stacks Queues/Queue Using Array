class myQueue{
    int[] arr;
    int front,rear,size;
    public myQueue(int n){
        arr=new int[n];
        front=0;
        rear=-1;
        size=0;
    }
    public boolean isEmpty(){
        return size==0;
    }
    public boolean isFull(){
        return size==arr.length;
    }
    public void enqueue(int x){
        if(!isFull()){
            rear=(rear+1)%arr.length;
            arr[rear]=x;
            size++;
        }
    }
    public void dequeue(){
        if(!isEmpty()){
            front=(front+1)%arr.length;
            size--;
        }
    }
    public int getFront(){
        if(isEmpty()) return -1;
        return arr[front];
    }
    public int getRear(){
        if(isEmpty()) return -1;
        return arr[rear];
    }
}
