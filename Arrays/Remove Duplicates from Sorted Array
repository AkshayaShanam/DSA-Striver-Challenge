class Solution {
    public int removeDuplicates(int[] nums) {
        int len=nums.length;
        int i=0;
        int j=1;
        while(j<len){
            if(nums[j]!=nums[i]){
                i+=1;
                nums[i]=nums[j];
            }
            else{
                j++;
            }
        }
        return i+1;
    }
}
