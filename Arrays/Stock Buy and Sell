import java.util.*;
class Solution {
    public int maxProfit(int[] prices) {
        int len=prices.length;
        int maxprofit=0;
        int mini=prices[0];
        for(int i=1;i<len;i++){
            mini=Math.min(mini,prices[i]);
            maxprofit=Math.max(maxprofit,prices[i]-mini);
        }
        return maxprofit;
    }
}
